[13.766162, "o", "\u001b[?25l\u001b[1;9H\u001b[m\u000f\u001b[38;2;198;120;221m\u001b[48;2;34;36;53mfunction\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m \u001b[m\u000f\u001b[38;2;37;171;228m\u001b[48;2;34;36;53mcreateUser\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m(\u001b[m\u000f\u001b[3m\u001b[38;2;225;103;101m\u001b[48;2;34;36;53mname\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m, \u001b[m\u000f\u001b[3m\u001b[38;2;225;103;101m\u001b[48;2;34;36;53mrole\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m) \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m{\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m                                 \u001b[2;11H\u001b[m\u000f\u001b[38;2;198;120;221m\u001b[48;2;34;36;53mconst\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m \u001b[m\u000f\u001b[38;2;234;160;65m\u001b[48;2;34;36;53muser\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m = \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m{\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m                                                      \u001b[3;17H,\u001b[4;17H,\u001b[5;21H: \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m{\n\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m: \u001b[m\u000f\u001b[38;2;70;163;175m\u001b[48;2;34;36;53mnew\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m \u001b[0;1m\u000f\u001b[38;2;234;232;82m\u001b[48;2;34;36;53mDate\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m().\u001b[m\u000f\u001b[38;2;70;163;175m\u001b[48;2;34;36;53mtoISOString\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m(),\u001b[7;26H: \u001b[m\u000f\u001b[3m\u001b[38;2;225;103;101m\u001b[48;2;34;36;53mrole\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m === \u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"admin\"\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m                  \u001b[8;17H? \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m[\u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"read\"\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m, \u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"write\"\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m, \u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"delete\"\u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m]\u001b[9;17H\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m: \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m[\u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"read\"\u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m]\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m,\u001b[10;23H: \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m{\u001b[11;22H\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m: \u001b[m\u000f\u001b[38;2;117;190;120m\u001b[48;2;34;36;53m\"dark\"\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m,\u001b[12;30H: \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m{\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53memail\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m: \u001b[m\u000f\u001b[38;2;234;160;65m\u001b[48;2;34;36;53mtrue\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m, \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53msms\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m: \u001b[m\u000f\u001b[38;2;234;160;65m\u001b[48;2;34;36;53mfalse\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m \u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m}\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m,\u001b[13;15H\u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m}\u001b[m\u000f\u001b[38;2;180;183;207m\u001b[48;2;34;36;53m,\u001b[14;13H\u001b[m\u000f\u001b[38;2;225;103;101m\u001b[48;2;34;36;53m}\u001b